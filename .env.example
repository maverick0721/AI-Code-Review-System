# AI review server endpoint used by the GitHub bot.
AI_SERVER=http://localhost:8000/review

# Local CLI endpoint for submitting prompts.
SERVER_URL=http://localhost:8000/review

# GitHub integration settings.
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=owner/repo
WEBHOOK_ID=123456789

# ngrok settings for webhook tunneling.
NGROK_AUTH_TOKEN=your_ngrok_auth_token
NGROK_URL=https://your-tunnel.ngrok.io